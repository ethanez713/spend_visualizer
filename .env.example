# Example env file. Copy to .env only if you need to override defaults; .env is
# gitignored. The tool needs NO secrets for its core path — it reads a local JSONL
# store and talks to a LOCAL Ollama. Drive sync uses .secrets/client_secret.json (OAuth),
# not env vars.

# Override the local Ollama endpoint (default: http://localhost:11434).
# A non-localhost host means your transaction data leaves this machine — avoid it.
# OLLAMA_HOST=http://localhost:11434
