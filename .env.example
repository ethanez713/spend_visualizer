# Copy to .env and fill in your own values from the Plaid Dashboard:
#   Developers -> Keys
#
# Trial plan note: the free Trial uses REAL data but the env string is "production".
# Use sandbox only for initial testing with Plaid's fake credentials.

PLAID_CLIENT_ID=your_client_id_here

# Use your Production secret when PLAID_ENV=production.
# Use your Sandbox secret when PLAID_ENV=sandbox.
PLAID_SECRET=your_secret_here

# production | sandbox
PLAID_ENV=production
