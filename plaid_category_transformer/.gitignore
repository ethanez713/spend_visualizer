# Runtime state + secrets — quarantined here, 0700, NEVER committed.
.secrets/

# Defensive secret patterns (catch a secret that lands outside .secrets/).
.env*
!.env.example
*secret*.json
token.json
drive_state.json
*.tmp

# Python / tooling
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
build/
dist/

# Local integration creds (real Ollama/Drive runs are manual + gitignored)
integration_tests/.secrets/

# ⚠ NOTE: data/ is DELIBERATELY NOT ignored. The categorized transaction store is
# committed on purpose (git + Drive dual audit history). This repo MUST be private.
