# Runtime state + secrets — quarantined here, 0700, NEVER committed.
.secrets/

# Defensive secret patterns (catch a secret that lands outside .secrets/).
.env*
!.env.example
*secret*.json
token.json
drive_state.json
*.tmp

# Python / tooling
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
build/
dist/

# Local integration creds (real Ollama/Drive runs are manual + gitignored)
integration_tests/.secrets/

# Personal data lives OUTSIDE this repo (the data root — see <monorepo>/data_root);
# defensive ignore in case anything ever writes here again. Its git audit history
# now lives in the private data repo.
data/
