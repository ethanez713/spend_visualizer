# Virtualenvs (per-component, rebuilt locally — never committed)
venv/
.venv/

# Python tooling
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
build/
dist/

# Defensive secret patterns — real secrets are quarantined in each component's
# .secrets/ (also ignored per-component); catch strays anywhere in the tree.
.secrets/
.secrets
.env*
!.env.example
*secret*.json
token*.json
drive_state.json
*.tmp

# ALL personal data lives OUTSIDE this repo (the external data root — see ./data_root);
# history was purged of it once already. Bare data/ rule as a last line of defense in
# case anything ever writes a data dir inside the repo again (components also ignore
# their own data/).
data/
