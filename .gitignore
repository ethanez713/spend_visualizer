# Runtime state, secrets, logs, raw archive — all quarantined here, never commit
var/

# Extra defensive secret patterns (in case a secret lands outside var/)
.env*
!.env.example
*secret*.json
token.json
tokens.json
sync_cursors.json
*.tmp

# Output deliverable (derived; regenerated each run)
transactions.csv

# Python / tooling
venv/
__pycache__/
*.pyc
.pytest_cache/
